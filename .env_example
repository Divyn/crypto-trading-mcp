# Bitquery API token — get yours at https://bitquery.io
BITQUERY_TOKEN=your_bitquery_token_here

# OpenAI API key — used internally to resolve natural language to GraphQL queries
# Get yours at https://platform.openai.com
OPENAI_API_KEY=your_openai_api_key_here

# Port the server listens on (Railway/Render set this automatically)
PORT=8000
